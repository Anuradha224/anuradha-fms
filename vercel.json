{
  "rewrites": [
    { "source": "/sw.js",    "destination": "/sw.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Content-Type",  "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
